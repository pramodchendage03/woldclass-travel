# Supabase Configuration
SUPABASE_URL=https://qtrlayriafeviwfnrbzt.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# JWT_SECRET: Secret key for JWT authentication.
JWT_SECRET="MY_SUPER_SECRET_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Stripe API Keys
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Nodemailer (Email) Configuration
# For Gmail: Use your email address as EMAIL_USER.
# For EMAIL_PASS: You MUST use a "Google App Password" (NOT your regular password).
# Generate one here: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=

# Twilio (SMS) Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# UPI Configuration
VITE_UPI_ID=7387625315-2@ybl
VITE_MERCHANT_NAME=WorldClass Travel
